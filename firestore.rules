rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required, immutable)
    //   - email: string (required)
    //   - displayName: string (optional)
    //   - photoURL: string (optional)
    //   - role: string (required, 'user' or 'admin')
    //   - createdAt: timestamp (required, immutable)
    //
    // Collection: curations
    // Document ID: {curationId}
    // Fields:
    //   - userId: string (required, immutable)
    //   - modernTitle: string (required)
    //   - historicalTitle: string (required)
    //   - modernEvent: string (required)
    //   - historicalEvent: string (required)
    //   - description: string (required)
    //   - imageUrl: string (optional)
    //   - link: string (optional)
    //   - createdAt: timestamp (required, immutable)
    //
    // Collection: daily_echoes
    // Document ID: {date} (YYYY-MM-DD)
    // Fields:
    //   - date: string (required, immutable)
    //   - echoes: list (required)
    //   - createdAt: timestamp (required, immutable)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }
    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "sibanda.nkazimulo@gmail.com" && request.auth.token.email_verified == true));
    }
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    function isValidString(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
             request.resource.data[field].size() >= minLen &&
             request.resource.data[field].size() <= maxLen;
    }
    function isValidOptionalString(field, minLen, maxLen) {
      return !('field' in request.resource.data) ||
             (request.resource.data[field] is string &&
              request.resource.data[field].size() >= minLen &&
              request.resource.data[field].size() <= maxLen);
    }
    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }
    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }
    function userIdUnchanged() {
      return !('userId' in request.resource.data) || request.resource.data.userId == request.auth.uid;
    }
    function userIdNotModified() {
      return !('userId' in request.resource.data) || request.resource.data.userId == resource.data.userId;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidUser(data) {
      return hasOnlyAllowedFields(['uid', 'email', 'displayName', 'photoURL', 'role', 'createdAt']) &&
             hasRequiredFields(['uid', 'email', 'role', 'createdAt']) &&
             isValidString('uid', 1, 128) &&
             isValidString('email', 3, 256) &&
             isValidOptionalString('displayName', 0, 100) &&
             isValidOptionalString('photoURL', 0, 2048) &&
             data.role in ['user', 'admin'] &&
             data.createdAt is timestamp;
    }

    function isValidCuration(data) {
      return hasOnlyAllowedFields(['userId', 'modernTitle', 'historicalTitle', 'modernEvent', 'historicalEvent', 'description', 'imageUrl', 'link', 'createdAt']) &&
             hasRequiredFields(['userId', 'modernTitle', 'historicalTitle', 'modernEvent', 'historicalEvent', 'description', 'createdAt']) &&
             isValidString('userId', 1, 128) &&
             isValidString('modernTitle', 1, 500) &&
             isValidString('historicalTitle', 1, 500) &&
             isValidString('modernEvent', 1, 500) &&
             isValidString('historicalEvent', 1, 500) &&
             isValidString('description', 1, 5000) &&
             isValidOptionalString('imageUrl', 0, 2048) &&
             isValidOptionalString('link', 0, 2048) &&
             data.createdAt is timestamp;
    }

    function isValidDailyEcho(data) {
      return hasOnlyAllowedFields(['date', 'echoes', 'createdAt']) &&
             hasRequiredFields(['date', 'echoes', 'createdAt']) &&
             isValidString('date', 10, 10) &&
             data.echoes is list &&
             data.echoes.size() <= 10 &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================
    
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && 
                    isOwner(userId) && 
                    isValidUser(request.resource.data) && 
                    uidUnchanged() && 
                    (request.resource.data.role == 'user' || isAdmin());
      allow update: if isAuthenticated() && 
                    isOwner(userId) && 
                    isValidUser(request.resource.data) && 
                    uidNotModified() && 
                    request.resource.data.createdAt == resource.data.createdAt &&
                    (request.resource.data.role == resource.data.role || isAdmin());
      allow delete: if isAdmin();
    }

    match /curations/{curationId} {
      allow read: if isAuthenticated() && request.auth.uid == resource.data.userId;
      allow create: if isAuthenticated() && 
                    isValidCuration(request.resource.data) && 
                    userIdUnchanged();
      allow update: if isAuthenticated() && 
                    isDocOwner() && 
                    isValidCuration(request.resource.data) && 
                    userIdNotModified() &&
                    request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isAuthenticated() && isDocOwner();
    }

    match /daily_echoes/{date} {
      allow read: if true; // Publicly readable to allow the app to fetch cached echoes
      allow create: if isAuthenticated() && isValidDailyEcho(request.resource.data);
      allow update: if isAdmin(); // Only admins can update cached echoes
      allow delete: if isAdmin();
    }
  }
}
